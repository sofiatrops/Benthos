# Plantilla de variables de entorno para desarrollo. Copiar a `.env` y ajustar.
# NUNCA versionar el archivo `.env` real (RNF-SEG-004).

# --- PostgreSQL (superusuario solo para administración del contenedor) ---
POSTGRES_DB=bep
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Rol de aplicación (lo usan la API y el Worker) ---
BEP_DB_CONNECTION=Host=postgres;Port=5432;Database=bep;Username=bep_app;Password=bep_app_dev

# --- Keycloak (IdP, ADR-003) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_AUTHORITY=http://keycloak:8080/realms/bep
KEYCLOAK_AUDIENCE=bep-api

# --- MinIO (almacenamiento de objetos S3-compatible, ADR-008) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Observabilidad (opcional: endpoint OTLP de un colector) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
